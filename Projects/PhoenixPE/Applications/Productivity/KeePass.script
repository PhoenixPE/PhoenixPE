[Main]
Title=KeePass
Description=(v2.61) KeePass is a free, open source, light-weight and easy-to-use password manager.
Author=Homes32
Level=5
Selected=False
Mandatory=False
Version=1.0.0.0
Date=2026-01-17

[Variables]
%ProgramFolder%="KeePass"
%ProgramExe%="KeePass.exe"
%ProgramVersion%="2.61"
%DownloadURL%=https://sourceforge.net/projects/keepass/files/KeePass#$p202.x/%ProgramVersion%/KeePass-%ProgramVersion%.zip/download
%SetupFile%="KeePass-%ProgramVersion%.zip"
%ConfigFile%="%TargetPrograms%\%ProgramFolder%\KeePass.config.xml"
%aLangMap%=Arabic|Arabic|Basque|Basque|Bulgarian|Bulgarian|Catalan|Catalan|Chinese (Simplified)|Chinese_Simplified|Chinese (Traditional)|Chinese_Traditional|Croatian|Croatian|Czech|Czech|Danish|Danish|Dutch|Dutch|English|English|Estonian|Estonian|Finnish|Finnish|French|French|German|German|Greek|Greek|Hebrew|Hebrew|Hungarian|Hungarian|Icelandic|Icelandic|Indonesian|Indonesian|Italian|Italian|Japanese|Japanese|Korean|Korean|Latin|Latin|Latvian|Latvian|Lithuanian|Lithuanian|Norwegian (Bokmål)|Norwegian_NB|Pashto|Pashto|Persian|Persian|Polish|Polish|Portuguese (Brazil)|Portuguese_BR|Portuguese (Portugal)|Portuguese_PT|Romanian|Romanian|Russian|Russian|Serbian (Cyrillic)|Serbian_Cyrillic|Serbian (Latin)|Serbian_Latin|Slovak|Slovak|Slovenian|Slovenian|Spanish|Spanish|Swedish|Swedish|Tamil|Tamil|Thai|Thai|Turkish|Turkish|Ukrainian|Ukrainian|Vietnamese|Vietnamese

[Process]
Echo,"Processing %ScriptTitle%..."

If,%cb_RunFromRam%,Equal,True,RunFromRam

///////////////////////////////////////////////////////////////////////////////////
// Extract

If,Not,ExistFile,"%ProgramsCache%\%ProgramFolder%\%SetupFile%",Run,%ScriptFile%,DownloadProgram
Echo,"Extracting files..."
Run,%ScriptFile%,ExtractProgram,"%TargetPrograms%\%ProgramFolder%"
ExtractAllFiles,%ScriptFile%,Config,"%TargetPrograms%\%ProgramFolder%"

///////////////////////////////////////////////////////////////////////////////////
// Settings

Echo,"Configuring %ScriptTitle%..."

// Language
Run,%ScriptFile%,ProcessLanguage

// Window Layout
XMLUpdate,%ConfigFile%,"Configuration/MainWindow/Layout",%cmb_WindowLayout%

// Show Detail View
If,%cb_ShowDetailsView%,Equal,True,XMLUpdate,%ConfigFile%,"Configuration/MainWindow/EntryView/Show","true"
Else,XMLUpdate,%ConfigFile%,"Configuration/MainWindow/EntryView/Show>","false"

// Default Database path
DirMake,"%TargetPrograms%\%ProgramFolder%\Database"
XMLUpdate,%ConfigFile%,"Configuration/Application/WorkingDirectories/Item","Database@Database"

// FileExt
Associate,"kdbx","%PEPrograms%\%ProgramFolder%\%ProgramExe%"

// Databases
If,Not,%fb_IncludeKBDXDir%,Equal,"",If,ExistDir,%fb_IncludeKBDXDir%,Begin
  Echo,"Processing KeePass database files..."
  FileCopy,"%fb_IncludeKBDXDir%\*.kdbx","%TargetPrograms%\%ProgramFolder%\Database"
End

// Plugins
If,Not,%fb_IncludePluginsDir%,Equal,"",If,ExistDir,%fb_IncludePluginsDir%,Begin
  Echo,"Processing KeePass plugin files..."
  FileCopy,"%fb_IncludePluginsDir%\*.*","%TargetPrograms%\%ProgramFolder%\Plugins"
End

// Config - Keep this after any config changes so if the users wants to provide their own config we don't overwrite it.
If,Not,%fb_IncludeConfigDir%,Equal,"",If,ExistDir,%fb_IncludeConfigDir%,Begin
  Echo,"Processing additional include files..."
  FileCopy,"%fb_IncludeConfigDir%\*.*","%TargetPrograms%\%ProgramFolder%"
End

///////////////////////////////////////////////////////////////////////////////////
// Shortcuts

If,%cb_DesktopShc%,Equal,True,AddShortcut,Desktop,"",%txt_ShortcutName%,"%PEPrograms%\%ProgramFolder%\%ProgramExe%","","%PEPrograms%\%ProgramFolder%"
If,%cb_StartMenuShc%,Equal,True,AddShortcut,StartMenu,%txt_StartMenuFolder%,%txt_ShortcutName%,"%PEPrograms%\%ProgramFolder%\%ProgramExe%","","%PEPrograms%\%ProgramFolder%"
If,%cb_PinToTaskbar%,Equal,True,PinShortcut,Taskbar,Auto,"%PEPrograms%\%ProgramFolder%\%ProgramExe%"
If,%cb_PinToStartMenu%,Equal,True,PinShortcut,StartMenu,Auto,"%PEPrograms%\%ProgramFolder%\%ProgramExe%"

[#ExtractProgram#]
// ===============================================================================================================================
// Name...........: ExtractProgram
// Description....: Extract program files from script/setup files.
// Syntax.........: Run,%ScriptFile%,ExtractProgram,<DestDir>
// Parameters.....: #1 DestDir - The directory where the files will be extracted.
// Return values..: 
// Author.........: Homes32
// Remarks........:
// Related........: 
// ===============================================================================================================================
[ExtractProgram]
Echo,"Extracting program files..."
Decompress,"%ProgramsCache%\%ProgramFolder%\%SetupFile%",#1

[#ProcessLanguage#]
// ===============================================================================================================================
// Name...........: ProcessLanguage
// Description....: Download any need language files and update the config.
// Syntax.........: Run,%ScriptFile%,ProcessLanguage
// Parameters.....: 
// Return values..: 
// Author.........: Homes32
// Remarks........: In order to maintain some sanity, we are simply looking for the language file for the current version. If 
//                  language files haven't been updated for the chosen locale we simply fallback to English.
// Related........: 
// ===============================================================================================================================
[ProcessLanguage]
If,%cmb_Language%,Equal,"English",XMLUpdate,%ConfigFile%,"Configuration/Application/LanguageFile","English.lngx"
Else,Begin  
  List,Pos,%aLangMap%,%cmb_Language%,%LangPos%
  If,%LangPos%,Equal,0,Halt,"Error: Language [%cmb_Language%] is not defined."
  Math,Add,%ZipPos%,%LangPos%,1
  List,Get,%aLangMap%,%ZipPos%,%LangZip%

  Set,%LangZipFile%,"KeePass-%ProgramVersion%-%LangZip%.zip"
   
  If,ExistFile,"%ProgramsCache%\%ProgramFolder%\%LangZipFile%",Begin
    Decompress,"%ProgramsCache%\%ProgramFolder%\%LangZipFile%","%TargetPrograms%\%ProgramFolder%\Languages"
    XMLUpdate,%ConfigFile%,"Configuration/Application/LanguageFile","%LangZip%.lngx"
  End
  Else,Begin
    Echo,"Downloading [%cmb_Language%] language files..."
    WebGet,"https://downloads.sourceforge.net/keepass/%LangZipFile%","%ProgramsCache%\%ProgramFolder%\%LangZipFile%",NOERR
    If,#r,Equal,200,Begin
      Decompress,"%ProgramsCache%\%ProgramFolder%\%LangZipFile%","%TargetPrograms%\%ProgramFolder%\Languages"
      XMLUpdate,%ConfigFile%,"Configuration/Application/LanguageFile","%LangZip%.lngx"
    End
    Else,Begin
      Echo,"Downloading language [%cmb_Language%] failed: The code returned was [#r]. It's possible that the translation has not yet been updated for this version. Falling back to [English].",Warn
      XMLUpdate,%ConfigFile%,"Configuration/Application/LanguageFile","English.lngx"
    End
  End
End

[#DownloadProgram#]
// ===============================================================================================================================
// Name...........: DownloadProgram
// Description....: Download the program files from the author's website.
// Syntax.........: Run,%ScriptFile%,DownloadProgram
// Parameters.....: 
// Return values..: 
// Author.........: Homes32
// Remarks........:
// Related........: 
// ===============================================================================================================================
[DownloadProgram]
Echo,"Downloading %ScriptTitle%..."
WebGet,%DownloadURL%,"%ProgramsCache%\%ProgramFolder%\%SetupFile%",NOERR
If,Not,#r,Equal,200,Halt,"Download failed: The code returned was [#r]."

[#LaunchProgram#]
// ===============================================================================================================================
// Name...........: LaunchProgram
// Description....: Unpack and launch the program.
// Syntax.........: Run,%ScriptFile%,LaunchProgram
// Parameters.....: 
// Return values..: 
// Author.........: Homes32
// Remarks........:
// Related........: btn_LaunchProgram
// ===============================================================================================================================
[LaunchProgram]
Echo,"Launching %ScriptTitle%..."
If,Not,ExistFile,"%ProgramsCache%\%ProgramFolder%\%SetupFile%",Run,%ScriptFile%,DownloadProgram
Echo,"Extracting files..."
Run,%ScriptFile%,ExtractProgram,"%ProjectTemp%\%ProgramFolder%"
ShellExecuteEx,Open,"%ProjectTemp%\%ProgramFolder%\%ProgramExe%"

[#BrowseIncludeDir#]
// ===============================================================================================================================
// Name...........: BrowseIncludeDir
// Description....: Explore the specified additional files and plugins folder.
// Syntax.........: 
// Parameters.....: 
// Return values..: 
// Author.........: Homes32
// Remarks........:
// Related........: btn_BrowseIncludeDir
// ===============================================================================================================================
[BrowseIncludeDir]
If,ExistDir,%fb_IncludeDir%,ShellExecuteEx,Explore,%fb_IncludeDir%
Else,Message,"The specified directory does not exist.",ERROR

[#ClearDownloadCache#]
// ===============================================================================================================================
// Name...........: ClearDownloadCache
// Description....: Remove all downloaded setup and program files.
// Syntax.........: Run,%ScriptFile%,ClearDownloadCache
// Parameters.....: 
// Return values..: 
// Author.........: Homes32
// Remarks........:
// Related........: btn_PurgeCache
// ===============================================================================================================================
[ClearDownloadCache]
DirDeleteEx,"%ProgramsCache%\%ProgramFolder%"

[#SetDefaultOptions#]
// ===============================================================================================================================
// Name...........: SetDefaultOptions
// Description....: Sets script options to default values.
// Syntax.........: 
// Parameters.....: 
// Return values..: 
// Author.........: Homes32
// Remarks........: 
// Related........: btn_SetDefaultOptions
// ===============================================================================================================================
[SetDefaultOptions]
System,Cursor,Wait
WriteInterface,Value,%ScriptFile%,Interface,cb_RunFromRam,True
WriteInterface,Value,%ScriptFile%,Interface,cb_DesktopShc,False
WriteInterface,Value,%ScriptFile%,Interface,cb_StartMenuShc,True
WriteInterface,Value,%ScriptFile%,Interface,cb_PinToTaskbar,False
WriteInterface,Value,%ScriptFile%,Interface,cb_PinToStartMenu,False
WriteInterface,Value,%ScriptFile%,Interface,txt_StartMenuFolder,"Productivity"
WriteInterface,Value,%ScriptFile%,Interface,txt_ShortcutName,"KeePass"
WriteInterface,Value,%ScriptFile%,Interface,cmb_Language,"English"
WriteInterface,Value,%ScriptFile%,Interface,cmb_WindowLayout,"Stacked"
WriteInterface,Value,%ScriptFile%,Interface,cb_ShowDetailsView,True
WriteInterface,Value,%ScriptFile%,Interface,fb_IncludeKBDXDir,""
WriteInterface,Value,%ScriptFile%,Interface,fb_IncludePluginsDir,""
WriteInterface,Value,%ScriptFile%,Interface,fb_IncludeConfigDir,""
System,Cursor,Normal

[#ToggleAdvancedOptions#]
// ===============================================================================================================================
// Name...........: ToggleAdvancedOptions
// Description....: Show/Hide advanced options.
// Syntax.........: 
// Parameters.....: 
// Return values..: 
// Author.........: Homes32
// Remarks........:
// Related........: btn_AdvancedOptions
// ===============================================================================================================================
[ToggleAdvancedOptions]
System,SetLocal
ReadInterface,Visible,%ScriptFile%,Interface,bvl_AdvancedOptions,%state%
If,%state%,Equal,False,Begin
  If,Question,"WARNING!#$x#$xAdvanced options are intended for expert users only!#$x#$xModifying advanced options without knowing what you are doing can cause permanent damage to your project and may result in unexpected behavior and/or build failures.#$x#$xAre you sure you want to continue?",Begin
	Set,%Toggle%,True
    WriteInterface,Resource,%ScriptFile%,Interface,btn_AdvancedOptions,Advanced_Exit_16.png
	WriteInterface,Tooltip,%ScriptFile%,Interface,btn_AdvancedOptions,"Hide Advanced Options"
  End
  Else,Set,%Toggle%,False
End
Else,Begin
  Set,%Toggle%,False
  WriteInterface,Resource,%ScriptFile%,Interface,btn_AdvancedOptions,Advanced_16.png
  WriteInterface,Tooltip,%ScriptFile%,Interface,btn_AdvancedOptions,"Show Advanced Options"
End

WriteInterface,Visible,%ScriptFile%,Interface,bvl_AdvancedOptions,%Toggle%
WriteInterface,Visible,%ScriptFile%,Interface,lbl_IncludeConfigDir,%Toggle%
WriteInterface,Visible,%ScriptFile%,Interface,fb_IncludeConfigDir,%Toggle%
WriteInterface,Visible,%ScriptFile%,Interface,btn_BrowseConfigDir,%Toggle%
System,EndLocal

[#ShowScriptInfo#]
// ===============================================================================================================================
// Name...........: ShowScriptInfo
// Description....: 
// Syntax.........: 
// Parameters.....: 
// Return values..: 
// Author.........: Homes32
// Remarks........:
// Related........: btn_ScriptInfo
// ===============================================================================================================================
[ShowScriptInfo]
Message,"KeePass is a free, open source, light-weight and easy-to-use password manager.#$x#$xThe first time this script is run it will download the setup file (~3MB) and cache it for future builds."

